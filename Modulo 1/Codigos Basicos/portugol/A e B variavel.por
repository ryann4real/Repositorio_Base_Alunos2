programa {
  funcao inicio() {
   inteiro a, b
  
    escreva("digite o valor para variavel A: ")
    leia(a)

    escreva("digite o valor para variavel B: ")
    leia(b)
  
  escreva("comparações:\n")
  escreva("a > b =", a > b, "\n")
  escreva("a < b = ", a < b, "\n")
  escreva("a != b = ", a != b, "\n")
  escreva("a == b ", a == b, "\n")
  }
}
