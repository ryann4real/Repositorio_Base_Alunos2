programa {
  funcao inicio() {
    
    
    inteiro numero
    logico ehPositivo
    logico ehNegativo
    logico ehZero

    escreva("digite um numero: ")
    leia(numero)

    ehPositivo = numero > 0

    escreva("esse numero é positivo? ",ehPositivo)

  ehNegativo = numero < 0

    escreva("\nesse numero é negativo? ",ehNegativo)

  ehZero = numero == 0

  escreva("\nesse numero é zero? ",ehZero)

  

  }
}
