programa {
  funcao inicio() {
     inteiro numero1 
    inteiro numero2
    inteiro resultado

    escreva("Digite o primeiro número:  ")
    leia(numero1)

    escreva("DIgite o segundo número: ")
    leia(numero2)

  resultado = numero1 - numero2

escreva("O resultado da subtração é: ", resultado)
  }
}
