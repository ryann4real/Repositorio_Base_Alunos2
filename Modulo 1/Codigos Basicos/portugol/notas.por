programa {
  funcao inicio() {
    cadeia nome
    real nota1
    real nota2
    real nota3
    real media

  escreva ("digite o nome do aluno: ")
    leia(nome)

  escreva ("digite a primeira nota: ")
  leia(nota1)

 escreva ("digite a segunda nota: ")
  leia(nota2)

   escreva ("digite a terceira nota: ")
  leia (nota3)
  
    media = (nota1 + nota2 + nota3) / 3
  escreva("A média das notas de ",nome," foi: ",media)
   } 
}
